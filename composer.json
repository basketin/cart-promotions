{
    "name": "basketin/cart-promotions",
    "description": "Cart promotions package for Basketin — discount rules, coupons and a promotion engine for Laravel e-commerce",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Karim Mohamed",
            "email": "komicho1996@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Obelaw\\Basketin\\Cart\\Promotions\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Obelaw\\Basketin\\Cart\\Promotions\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.1||^8.2",
        "laravel/framework": "^11.0||^12.0",
        "basketin/cart": "2.x-dev"
    },
    "require-dev": {
        "orchestra/testbench": "^10.9",
        "pestphp/pest-plugin-laravel": "^4.1",
        "laravel/legacy-factories": "^1.4",
        "mockery/mockery": "^1.6"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "./vendor/bin/pest"
    }
}